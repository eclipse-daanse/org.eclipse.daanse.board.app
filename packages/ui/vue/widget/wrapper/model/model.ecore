<ecore:EPackage xmi:version="2.0"
                xmlns:xmi="http://www.omg.org/XMI"
                xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                xmlns:ecore="http://www.eclipse.org/emf/2002/Ecore"
                name="wrapperSettings"
                nsURI="http://www.example.org/wrapperSettings"
                nsPrefix="wrapperSettings">
    <eClassifiers xsi:type="ecore:EClass" name="WrapperSettings">
        <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
            <details key="documentation" value="Represents a comprehensive set of visual and layout settings for a UI wrapper component, controlling aspects like background, title, borders, shadows, and overall appearance."/>
        </eAnnotations>

        <eStructuralFeatures xsi:type="ecore:EReference" name="title" containment="false" defaultValueLiteral="">
            <eGenericType eClassifier="org.eclipse.daanse.board.app.ui.vue.composables#//VariableWrapper">
                <eTypeArguments eClassifier="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EString"/>
            </eGenericType>
            <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
                <details key="documentation" value="The optional title text to be displayed within the wrapper."/>
            </eAnnotations>
        </eStructuralFeatures>

        <eStructuralFeatures xsi:type="ecore:EReference" name="backgroundColor" containment="false" defaultValueLiteral="#fff">
            <eGenericType eClassifier="org.eclipse.daanse.board.app.ui.vue.composables#//VariableWrapper">
                <eTypeArguments eClassifier="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EString"/>
            </eGenericType>
            <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
                <details key="documentation" value="The background color of the wrapper, typically represented as a hexadecimal string (e.g., '#RRGGBB')."/>
            </eAnnotations>
        </eStructuralFeatures>

        <eStructuralFeatures xsi:type="ecore:EReference" name="backgroundColorTransparence" containment="false" defaultValueLiteral="255">
            <eGenericType eClassifier="org.eclipse.daanse.board.app.ui.vue.composables#//VariableWrapper">
                <eTypeArguments eClassifier="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EString"/>
            </eGenericType>
            <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
                <details key="documentation" value="The transparency level of the background color, ranging from 0.0 (fully transparent) to 1.0 (fully opaque)."/>
            </eAnnotations>
        </eStructuralFeatures>

        <eStructuralFeatures xsi:type="ecore:EReference" name="titleColor" containment="false" defaultValueLiteral="#7c7c7c">
            <eGenericType eClassifier="org.eclipse.daanse.board.app.ui.vue.composables#//VariableWrapper">
                <eTypeArguments eClassifier="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EString"/>
            </eGenericType>
            <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
                <details key="documentation" value="The color of the title text, typically as a hexadecimal string."/>
            </eAnnotations>
        </eStructuralFeatures>

        <eStructuralFeatures xsi:type="ecore:EReference" name="padding" containment="false" defaultValueLiteral="0">
            <eGenericType eClassifier="org.eclipse.daanse.board.app.ui.vue.composables#//VariableWrapper">
                <eTypeArguments eClassifier="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EString"/>
            </eGenericType>
            <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
                <details key="documentation" value="The inner spacing (padding) within the wrapper, usually in pixels."/>
            </eAnnotations>
        </eStructuralFeatures>

        <eStructuralFeatures xsi:type="ecore:EReference" name="titleFontSize" containment="false" defaultValueLiteral="15">
            <eGenericType eClassifier="org.eclipse.daanse.board.app.ui.vue.composables#//VariableWrapper">
                <eTypeArguments eClassifier="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EString"/>
            </eGenericType>
            <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
                <details key="documentation" value="The font size of the title text, typically in pixels."/>
            </eAnnotations>
        </eStructuralFeatures>

        <eStructuralFeatures xsi:type="ecore:EReference" name="borderSize" containment="false" defaultValueLiteral="0">
            <eGenericType eClassifier="org.eclipse.daanse.board.app.ui.vue.composables#//VariableWrapper">
                <eTypeArguments eClassifier="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EString"/>
            </eGenericType>
            <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
                <details key="documentation" value="The thickness of the wrapper's border, usually in pixels."/>
            </eAnnotations>
        </eStructuralFeatures>

        <eStructuralFeatures xsi:type="ecore:EReference" name="borderColor" containment="false" defaultValueLiteral="#ccc">
            <eGenericType eClassifier="org.eclipse.daanse.board.app.ui.vue.composables#//VariableWrapper">
                <eTypeArguments eClassifier="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EString"/>
            </eGenericType>
            <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
                <details key="documentation" value="The color of the wrapper's border, typically as a hexadecimal string."/>
            </eAnnotations>
        </eStructuralFeatures>

        <eStructuralFeatures xsi:type="ecore:EReference" name="borderRadius" containment="false" defaultValueLiteral="15">
            <eGenericType eClassifier="org.eclipse.daanse.board.app.ui.vue.composables#//VariableWrapper">
                <eTypeArguments eClassifier="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EString"/>
            </eGenericType>
            <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
                <details key="documentation" value="The radius for rounding the corners of the wrapper, usually in pixels."/>
            </eAnnotations>
        </eStructuralFeatures>

        <eStructuralFeatures xsi:type="ecore:EReference" name="blur" containment="false" defaultValueLiteral="0">
            <eGenericType eClassifier="org.eclipse.daanse.board.app.ui.vue.composables#//VariableWrapper">
                <eTypeArguments eClassifier="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EString"/>
            </eGenericType>
            <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
                <details key="documentation" value="The amount of blur applied to the wrapper's background or content, usually in pixels."/>
            </eAnnotations>
        </eStructuralFeatures>

        <eStructuralFeatures xsi:type="ecore:EReference" name="fullscreen" containment="false" defaultValueLiteral="false">
            <eGenericType eClassifier="org.eclipse.daanse.board.app.ui.vue.composables#//VariableWrapper">
                <eTypeArguments eClassifier="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EString"/>
            </eGenericType>
            <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
                <details key="documentation" value="A boolean flag indicating if the wrapper should occupy the full screen."/>
            </eAnnotations>
        </eStructuralFeatures>

        <eStructuralFeatures xsi:type="ecore:EReference" name="shadowColor" containment="false" defaultValueLiteral="#333">
            <eGenericType eClassifier="org.eclipse.daanse.board.app.ui.vue.composables#//VariableWrapper">
                <eTypeArguments eClassifier="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EString"/>
            </eGenericType>
            <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
                <details key="documentation" value="The color of the shadow applied to the wrapper, typically as a hexadecimal string."/>
            </eAnnotations>
        </eStructuralFeatures>

        <eStructuralFeatures xsi:type="ecore:EReference" name="shadowBlur" containment="false" defaultValueLiteral="12">
            <eGenericType eClassifier="org.eclipse.daanse.board.app.ui.vue.composables#//VariableWrapper">
                <eTypeArguments eClassifier="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EString"/>
            </eGenericType>
            <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
                <details key="documentation" value="The blur radius of the shadow, usually in pixels."/>
            </eAnnotations>
        </eStructuralFeatures>

        <eStructuralFeatures xsi:type="ecore:EReference" name="shadowX" containment="false" defaultValueLiteral="5">
            <eGenericType eClassifier="org.eclipse.daanse.board.app.ui.vue.composables#//VariableWrapper">
                <eTypeArguments eClassifier="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EString"/>
            </eGenericType>
            <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
                <details key="documentation" value="The horizontal offset of the shadow from the wrapper, usually in pixels."/>
            </eAnnotations>
        </eStructuralFeatures>

        <eStructuralFeatures xsi:type="ecore:EReference" name="shadowY" containment="false" defaultValueLiteral="5">
            <eGenericType eClassifier="org.eclipse.daanse.board.app.ui.vue.composables#//VariableWrapper">
                <eTypeArguments eClassifier="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EString"/>
            </eGenericType>
            <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
                <details key="documentation" value="The vertical offset of the shadow from the wrapper, usually in pixels."/>
            </eAnnotations>
        </eStructuralFeatures>

        <eStructuralFeatures xsi:type="ecore:EReference" name="shadowTransparence" containment="false" defaultValueLiteral="25">
            <eGenericType eClassifier="org.eclipse.daanse.board.app.ui.vue.composables#//VariableWrapper">
                <eTypeArguments eClassifier="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EString"/>
            </eGenericType>
            <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
                <details key="documentation" value="The transparency level of the shadow, ranging from 0.0 to 1.0."/>
            </eAnnotations>
        </eStructuralFeatures>

        <eStructuralFeatures xsi:type="ecore:EReference" name="transparency" containment="false" defaultValueLiteral="255">
            <eGenericType eClassifier="org.eclipse.daanse.board.app.ui.vue.composables#//VariableWrapper">
                <eTypeArguments eClassifier="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EString"/>
            </eGenericType>
            <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
                <details key="documentation" value="The overall transparency of the entire wrapper component, ranging from 0.0 to 1.0."/>
            </eAnnotations>
        </eStructuralFeatures>

    </eClassifiers>
</ecore:EPackage>
