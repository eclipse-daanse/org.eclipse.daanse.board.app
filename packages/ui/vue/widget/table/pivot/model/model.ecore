<xmi:XMI xmi:version="2.1" xmlns:xmi="http://www.omg.org/XMI" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:ecore="http://www.eclipse.org/emf/2002/Ecore" xmlns:PivotTable="http://www.example.org/PivotTable">
  <ecore:EPackage name="PivotTable" nsURI="http://www.example.org/PivotTable" nsPrefix="PivotTable">
    <eClassifiers xsi:type="ecore:EClass" name="PivotTable" eTypeParameters.0="PivotTable:IPivotTable">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation">Represents a pivot table structure.  Contains rows, columns, cells, and table state information.</details>
      </eAnnotations>
      <eStructuralFeatures xsi:type="ecore:EReference" name="rows" lowerBound="1" upperBound="-1" eType="#//JavaObject" containment="true">
        <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
          <details key="documentation">Rows of the pivot table.  Can contain any type of data.</details>
        </eAnnotations>
      </eStructuralFeatures>
      <eStructuralFeatures xsi:type="ecore:EReference" name="columns" lowerBound="1" upperBound="-1" eType="#//JavaObject" containment="true">
        <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
          <details key="documentation">Columns of the pivot table. Can contain any type of data.</details>
        </eAnnotations>
      </eStructuralFeatures>
      <eStructuralFeatures xsi:type="ecore:EReference" name="cells" lowerBound="1" upperBound="-1" eType="#//JavaObject" containment="true">
        <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
          <details key="documentation">Cells of the pivot table. Can contain any type of data.</details>
        </eAnnotations>
      </eStructuralFeatures>
      <eStructuralFeatures xsi:type="ecore:EAttribute" name="tableState" lowerBound="0" eType="ecore:EJavaObject">
        <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
          <details key="documentation">The overall state of the pivot table. Can be any type of data.</details>
        </eAnnotations>
      </eStructuralFeatures>

      <!-- New Style and Variable Properties -->
      <eStructuralFeatures xsi:type="ecore:EReference" name="headerBackgroundColor" containment="false" defaultValueLiteral="#f5f5f5">
        <eGenericType eClassifier="org.eclipse.daanse.board.app.ui.vue.composables#//VariableWrapper">
          <eTypeArguments eClassifier="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EString"/>
        </eGenericType>
      </eStructuralFeatures>
      <eStructuralFeatures xsi:type="ecore:EReference" name="headerTextColor" containment="false" defaultValueLiteral="#000000">
        <eGenericType eClassifier="org.eclipse.daanse.board.app.ui.vue.composables#//VariableWrapper">
          <eTypeArguments eClassifier="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EString"/>
        </eGenericType>
      </eStructuralFeatures>
      <eStructuralFeatures xsi:type="ecore:EReference" name="cellBackgroundColor" containment="false" defaultValueLiteral="#ffffff">
        <eGenericType eClassifier="org.eclipse.daanse.board.app.ui.vue.composables#//VariableWrapper">
          <eTypeArguments eClassifier="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EString"/>
        </eGenericType>
      </eStructuralFeatures>
      <eStructuralFeatures xsi:type="ecore:EReference" name="cellTextColor" containment="false" defaultValueLiteral="#000000">
        <eGenericType eClassifier="org.eclipse.daanse.board.app.ui.vue.composables#//VariableWrapper">
          <eTypeArguments eClassifier="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EString"/>
        </eGenericType>
      </eStructuralFeatures>
      <eStructuralFeatures xsi:type="ecore:EReference" name="borderColor" containment="false" defaultValueLiteral="silver">
        <eGenericType eClassifier="org.eclipse.daanse.board.app.ui.vue.composables#//VariableWrapper">
          <eTypeArguments eClassifier="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EString"/>
        </eGenericType>
      </eStructuralFeatures>
      <eStructuralFeatures xsi:type="ecore:EReference" name="defaultColumnWidth" containment="false" defaultValueLiteral="150">
        <eGenericType eClassifier="org.eclipse.daanse.board.app.ui.vue.composables#//VariableWrapper">
          <eTypeArguments eClassifier="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EString"/>
        </eGenericType>
      </eStructuralFeatures>
      <eStructuralFeatures xsi:type="ecore:EReference" name="defaultRowHeight" containment="false" defaultValueLiteral="30">
        <eGenericType eClassifier="org.eclipse.daanse.board.app.ui.vue.composables#//VariableWrapper">
          <eTypeArguments eClassifier="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EString"/>
        </eGenericType>
      </eStructuralFeatures>
      <eStructuralFeatures xsi:type="ecore:EReference" name="fontSize" containment="false" defaultValueLiteral="14">
        <eGenericType eClassifier="org.eclipse.daanse.board.app.ui.vue.composables#//VariableWrapper">
          <eTypeArguments eClassifier="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EString"/>
        </eGenericType>
      </eStructuralFeatures>
      <eStructuralFeatures xsi:type="ecore:EReference" name="headerFontWeight" containment="false" defaultValueLiteral="600">
        <eGenericType eClassifier="org.eclipse.daanse.board.app.ui.vue.composables#//VariableWrapper">
          <eTypeArguments eClassifier="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EString"/>
        </eGenericType>
      </eStructuralFeatures>
      
      <!-- Native non-variable properties -->
      <eStructuralFeatures xsi:type="ecore:EAttribute" name="cellTextAlign" eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EString" defaultValueLiteral="left" />
      <eStructuralFeatures xsi:type="ecore:EAttribute" name="showRowsProperties" eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EBoolean" defaultValueLiteral="false" />
      <eStructuralFeatures xsi:type="ecore:EAttribute" name="showColumnsProperties" eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EBoolean" defaultValueLiteral="false" />

      <!-- Nested Array Containment -->
      <eStructuralFeatures xsi:type="ecore:EReference" name="rowLevelStyles" lowerBound="0" upperBound="-1" eType="#//LevelStyle" containment="true" />
      <eStructuralFeatures xsi:type="ecore:EReference" name="columnLevelStyles" lowerBound="0" upperBound="-1" eType="#//LevelStyle" containment="true" />
      <eStructuralFeatures xsi:type="ecore:EReference" name="conditionalFormats" lowerBound="0" upperBound="-1" eType="#//ConditionalFormat" containment="true" />

    </eClassifiers>

    <!-- New nested classes -->
    <eClassifiers xsi:type="ecore:EClass" name="LevelStyle">
      <eStructuralFeatures xsi:type="ecore:EAttribute" name="level" eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EDouble" />
      <eStructuralFeatures xsi:type="ecore:EReference" name="backgroundColor" containment="false" defaultValueLiteral="#f5f5f5">
        <eGenericType eClassifier="org.eclipse.daanse.board.app.ui.vue.composables#//VariableWrapper">
          <eTypeArguments eClassifier="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EString"/>
        </eGenericType>
      </eStructuralFeatures>
      <eStructuralFeatures xsi:type="ecore:EReference" name="textColor" containment="false" defaultValueLiteral="#000000">
        <eGenericType eClassifier="org.eclipse.daanse.board.app.ui.vue.composables#//VariableWrapper">
          <eTypeArguments eClassifier="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EString"/>
        </eGenericType>
      </eStructuralFeatures>
      <eStructuralFeatures xsi:type="ecore:EAttribute" name="fontWeight" eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EDouble" defaultValueLiteral="600" />
    </eClassifiers>

    <eClassifiers xsi:type="ecore:EClass" name="ConditionalFormat">
      <eStructuralFeatures xsi:type="ecore:EAttribute" name="id" eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EString" />
      <eStructuralFeatures xsi:type="ecore:EAttribute" name="conditionType" eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EString" defaultValueLiteral="greaterThan" />
      <eStructuralFeatures xsi:type="ecore:EAttribute" name="priority" eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EDouble" />
      <eStructuralFeatures xsi:type="ecore:EAttribute" name="value1" eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EString" defaultValueLiteral="0" />
      <eStructuralFeatures xsi:type="ecore:EAttribute" name="value2" eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EString" defaultValueLiteral="100" />
      
      <eStructuralFeatures xsi:type="ecore:EReference" name="backgroundColor" containment="false" defaultValueLiteral="#ffcccc">
        <eGenericType eClassifier="org.eclipse.daanse.board.app.ui.vue.composables#//VariableWrapper">
          <eTypeArguments eClassifier="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EString"/>
        </eGenericType>
      </eStructuralFeatures>
      <eStructuralFeatures xsi:type="ecore:EReference" name="textColor" containment="false" defaultValueLiteral="#000000">
        <eGenericType eClassifier="org.eclipse.daanse.board.app.ui.vue.composables#//VariableWrapper">
          <eTypeArguments eClassifier="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EString"/>
        </eGenericType>
      </eStructuralFeatures>
      <eStructuralFeatures xsi:type="ecore:EReference" name="minColor" containment="false" defaultValueLiteral="#ffffff">
        <eGenericType eClassifier="org.eclipse.daanse.board.app.ui.vue.composables#//VariableWrapper">
          <eTypeArguments eClassifier="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EString"/>
        </eGenericType>
      </eStructuralFeatures>
      <eStructuralFeatures xsi:type="ecore:EReference" name="maxColor" containment="false" defaultValueLiteral="#ff0000">
        <eGenericType eClassifier="org.eclipse.daanse.board.app.ui.vue.composables#//VariableWrapper">
          <eTypeArguments eClassifier="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EString"/>
        </eGenericType>
      </eStructuralFeatures>
      <eStructuralFeatures xsi:type="ecore:EAttribute" name="fontWeight" eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EDouble" defaultValueLiteral="400" />
    </eClassifiers>
    <eClassifiers xsi:type="ecore:EClass" name="JavaObject" abstract="true">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation">A generic type for handling 'any' types in TypeScript. Maps to EJavaObject in Ecore.</details>
      </eAnnotations>
    </eClassifiers>
    <eClassifiers xsi:type="ecore:EClass" name="PivotTableInterface" abstract="true"  eSuperTypes="http://org.eclipse.daanse.board.app.lib.events#//WidgetActionInterface">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation">Abstract base class for PivotTable operations.</details>
      </eAnnotations>
      <eOperations name="expandRow">
        <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
          <details key="documentation">Expands the specified row in the pivot table.</details>
        </eAnnotations>
        <eAnnotations source="org.eclipse.daanse.board.app.lib.events/WidgetAction">
          <details key="eventType" value="pivotTable.expandRow"/>
        </eAnnotations>
        <eParameters name="rowUniqueName" eType="ecore:EString">
          <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
            <details key="documentation">The unique identifier of the row to expand.</details>
          </eAnnotations>
        </eParameters>
      </eOperations>
    </eClassifiers>
    <eClassifiers xsi:type="ecore:EClass" name="HeaderExpandedPayload" eSuperTypes="http://org.eclipse.daanse.board.app.lib.events#//Payload">
        <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
            <details key="documentation" value="Payload emitted when a header is expanded in the pivot table."/>
        </eAnnotations>
        <eStructuralFeatures xsi:type="ecore:EAttribute" name="uniqueName" eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EString">
            <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
                <details key="documentation" value="Header Unique Name."/>
            </eAnnotations>
        </eStructuralFeatures>
    </eClassifiers>
    <eClassifiers xsi:type="ecore:EClass" name="HeaderClickedPayload" eSuperTypes="http://org.eclipse.daanse.board.app.lib.events#//Payload">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
            <details key="documentation" value="Payload emitted when a header is clicked in the pivot table."/>
        </eAnnotations>
        <eStructuralFeatures xsi:type="ecore:EAttribute" name="uniqueName" eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EString">
            <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
                <details key="documentation" value="Header Unique Name."/>
            </eAnnotations>
        </eStructuralFeatures>
    </eClassifiers>
  </ecore:EPackage>
</xmi:XMI>